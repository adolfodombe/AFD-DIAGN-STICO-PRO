rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - role: string (required) - 'user' or 'assistant'
    //   - content: string (required) - Text content of the message
    //   - image: string (optional) - Base64 image data
    //   - timestamp: timestamp (required) - Creation time
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (optional) - 'user' or 'admin'
    //   - subscriptionType: string (required) - 'trial', 'premium', 'lifetime'
    //   - subscriptionExpiresAt: timestamp (optional)
    //   - createdAt: timestamp (required)
    //   - jobTitle: string (optional)
    //   - technicalLevel: string (optional)
    //   - bio: string (optional)
    //
    // Collection: activationCodes
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - days: number (required)
    //   - isUsed: boolean (required)
    //   - usedBy: string (optional)
    //   - usedAt: timestamp (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "adolfodombe@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidMessage(data) {
      return hasRequiredFields(['userId', 'role', 'content', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'role', 'content', 'timestamp', 'image']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 10000 &&
             (!('image' in data) || data.image == null || (data.image is string && data.image.size() <= 5000000)) &&
             data.timestamp is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'subscriptionType', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'subscriptionType', 'subscriptionExpiresAt', 'createdAt', 'jobTitle', 'technicalLevel', 'bio']) &&
             data.email is string &&
             data.subscriptionType in ['trial', 'premium', 'lifetime'] &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('jobTitle' in data) || (data.jobTitle is string && data.jobTitle.size() <= 100)) &&
             (!('technicalLevel' in data) || (data.technicalLevel is string && data.technicalLevel.size() <= 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000));
    }

    function isValidActivationCode(data) {
      return hasRequiredFields(['code', 'days', 'isUsed', 'createdAt']) &&
             hasOnlyAllowedFields(['code', 'days', 'isUsed', 'usedBy', 'usedAt', 'createdAt']) &&
             data.code is string &&
             data.days is number &&
             data.isUsed is bool &&
             data.createdAt is timestamp;
    }

    function isValidDiagnosis(data) {
      return hasRequiredFields(['userId', 'amplifierModel', 'symptoms', 'recommendations', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'amplifierModel', 'symptoms', 'recommendations', 'fullHistory', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.amplifierModel is string && data.amplifierModel.size() <= 200 &&
             data.symptoms is string && data.symptoms.size() <= 5000 &&
             data.recommendations is string && data.recommendations.size() <= 10000 &&
             (!('fullHistory' in data) || data.fullHistory is list) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /messages/{messageId} {
      // Users can only read their own messages
      allow read: if isDocOwner() || isAdmin();
      
      // Users can create messages for themselves
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      
      // Messages are generally immutable in this app, but let's allow deletion by owner
      allow delete: if isDocOwner() || isAdmin();
      
      // No updates allowed for messages to prevent history tampering
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation of user profile on first login
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (isAdmin() || request.resource.data.subscriptionType == 'trial') &&
                      (isAdmin() || request.resource.data.role == 'user');
      
      // Allow update of subscription info by admin or self
      // But only admin can change role or set lifetime
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || (
          isOwner(userId) && 
          request.resource.data.role == resource.data.role && 
          (request.resource.data.subscriptionType != 'lifetime' || resource.data.subscriptionType == 'lifetime') &&
          areImmutableFieldsUnchanged(['uid', 'email', 'createdAt'])
        )
      );

      // Allow admin to delete users if needed
      allow delete: if isAdmin();
    }

    match /activationCodes/{codeId} {
      // Only admin can list, create or delete codes
      allow list, create, delete: if isAdmin();
      
      // Users can check a specific code if they know the ID (usually query by code field)
      allow get: if isAuthenticated();
      
      // Allow users to mark a code as used
      allow update: if isAuthenticated() && 
                      isValidActivationCode(request.resource.data) &&
                      resource.data.isUsed == false &&
                      request.resource.data.isUsed == true &&
                      request.resource.data.usedBy == request.auth.uid &&
                      areImmutableFieldsUnchanged(['code', 'days', 'createdAt']);
    }

    match /diagnostics/{diagnosisId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidDiagnosis(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
      allow update: if false;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
