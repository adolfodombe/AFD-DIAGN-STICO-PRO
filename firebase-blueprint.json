{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A diagnostic message in the chat history.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this message."
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant"],
          "description": "The role of the message sender."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "image": {
          "type": "string",
          "description": "Optional base64 image data."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was sent."
        }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "User profile and subscription data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "subscriptionType": { "type": "string", "enum": ["trial", "premium", "lifetime"] },
        "subscriptionExpiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "jobTitle": { "type": "string" },
        "technicalLevel": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["email", "subscriptionType", "createdAt"]
    },
    "ActivationCode": {
      "title": "ActivationCode",
      "description": "Codes used to activate premium subscriptions.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "days": { "type": "integer" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "usedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "days", "isUsed", "createdAt"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "A saved diagnostic record for a specific amplifier.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amplifierModel": { "type": "string" },
        "symptoms": { "type": "string" },
        "recommendations": { "type": "string" },
        "fullHistory": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amplifierModel", "symptoms", "recommendations", "createdAt"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Collection of diagnostic messages."
    },
    "users": {
      "schema": "User",
      "description": "User profiles and subscription status."
    },
    "activationCodes": {
      "schema": "ActivationCode",
      "description": "Codes for activating premium features."
    },
    "diagnostics": {
      "schema": "Diagnosis",
      "description": "Saved diagnostic records for future reference."
    }
  }
}
